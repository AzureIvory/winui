                    "children": [
                      {
                        "type": "label",
                        "id": "panelInfo",
                        "text": "Click this surface to update the status area. The function test also exercises Panel.Add, Panel.Remove, and Panel.SetLayout on runtime-created content.",
                        "multiline": true,
                        "wordWrap": true,
                        "style": {
                          "align": "start",
                          "fg": "#475569"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },          {
