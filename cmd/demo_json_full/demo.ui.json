            },
            "style": {
              "bg": "#ffffff",
              "border": "#d6deea",
              "borderW": 1,
              "radius": 18
            },
            "frame": {
              "x": 20,
              "y": 108,
              "r": 380,
              "b": 20
            },
            "children": [
              {
                "type": "panel",
                "id": "introCard",
                "layout": {
                  "type": "col",
                  "gap": 10,
                  "pad": [18, 18, 18, 18]
