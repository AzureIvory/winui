                      {
                        "type": "button",
                        "id": "miniScrollBtn2",
                        "text": "Card B"
                      },
                      {
                        "type": "button",
                        "id": "miniScrollBtn3",
                        "text": "Card C"
                      },
                      {
                        "type": "button",
                        "id": "miniScrollBtn4",
                        "text": "Card D"
                      },
                      {
                        "type": "button",
                        "id": "miniScrollBtn5",
                        "text": "Card E"
                      },
                      {
                        "type": "button",
                        "id": "miniScrollBtn6",
                        "text": "Card F"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "panel",
                "id": "panelCard",
                "layout": {
                  "type": "col",
                  "gap": 12,
                  "pad": [18, 18, 18, 18]
                },
                "style": {
                  "bg": "#ffffff",
                  "border": "#d6deea",
                  "borderW": 1,
                  "radius": 16
                },
                "children": [
                  {
                    "type": "label",
                    "id": "panelTitle",
