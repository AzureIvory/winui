                    "wordWrap": true,
                    "style": {
                      "align": "start",
                      "fg": "#475569"
                    }
                  },
                  {
                    "type": "label",
                    "id": "paletteValue",
                    "text": {
                      "bind": "demo.paletteName",
                      "default": "Ocean Blue"
                    },
                    "style": {
                      "size": 14,
                      "weight": "bold",
                      "align": "start",
                      "fg": "#2563eb"
                    }
                  }
                ]
              },
              {
                "type": "panel",
                "id": "buttonsCard",
                "layout": {
                  "type": "col",
                  "gap": 12,
                  "pad": [18, 18, 18, 18]
                },
                "style": {
                  "bg": "#ffffff",
                  "border": "#d6deea",
                  "borderW": 1,
                  "radius": 16
                },
                "children": [
                  {
                    "type": "label",
                    "id": "buttonsTitle",
                    "text": "Buttons",
                    "style": {
                      "size": 18,
                      "weight": "bold",
                      "align": "start"
                    }
                  },
                  {
                    "type": "label",
                    "id": "buttonsHint",
                    "text": "Primary, image-left, image-top, ghost, and disabled states are all included in one section.",
                    "multiline": true,
                    "wordWrap": true,
                    "style": {
                      "align": "start",
                      "fg": "#64748b"
                    }
                  },
                  {
                    "type": "panel",
                    "id": "buttonsGrid",
                    "layout": {
                      "type": "grid",
                      "cols": 2,
                      "gap": 12
                    },
                    "children": [
                      {
                        "type": "button",
                        "id": "saveBtn",
                        "text": "Save changes",
                        "image": "assets/save.png",
                        "imagePos": "left"
                      },
                      {
                        "type": "button",
                        "id": "imageTopBtn",
                        "text": "Top image",
                        "image": "assets/palette.png",
                        "imagePos": "top"
                      },
                      {
                        "type": "button",
                        "id": "ghostBtn",
                        "text": "Ghost action"
                      },
                      {
                        "type": "button",
                        "id": "disabledBtn",
                        "text": "Disabled action",
                        "enabled": false
                      }
                    ]
                  }
                ]
              },              {
                "type": "panel",
                "id": "inputCard",
                "layout": {
                  "type": "col",
                  "gap": 12,
                  "pad": [18, 18, 18, 18]
                },
                "style": {
                  "bg": "#ffffff",
                  "border": "#d6deea",
                  "borderW": 1,
                  "radius": 16
                },
                "children": [
                  {
                    "type": "label",
                    "id": "inputTitle",
                    "text": "Inputs",
                    "style": {
                      "size": 18,
                      "weight": "bold",
                      "align": "start"
                    }
                  },
                  {
                    "type": "label",
                    "id": "inputHint",
                    "text": "Single-line, password, and read-only multiline input states are all present here.",
                    "multiline": true,
                    "wordWrap": true,
                    "style": {
                      "align": "start",
                      "fg": "#64748b"
                    }
                  },
                  {
                    "type": "input",
                    "id": "nameInput",
                    "placeholder": "Project name"
                  },
                  {
                    "type": "input",
                    "id": "passwordInput",
                    "input": "password",
                    "placeholder": "Type a secret"
                  },
                  {
                    "type": "textarea",
                    "id": "notesBox",
                    "readOnly": true,
                    "placeholder": "Notes",
                    "value": "JSON declares structure and bindings. The host runtime still owns mutations, actions, and API checks."
                  }
                ]
              },
              {
                "type": "panel",
                "id": "choiceCard",
                "layout": {
                  "type": "col",
                  "gap": 12,
                  "pad": [18, 18, 18, 18]
                },
                "style": {
                  "bg": "#ffffff",
                  "border": "#d6deea",
                  "borderW": 1,
                  "radius": 16
                },
                "children": [
                  {
                    "type": "label",
                    "id": "choiceTitle",
                    "text": "Checks and radios",
                    "style": {
                      "size": 18,
                      "weight": "bold",
                      "align": "start"
                    }
                  },
                  {
                    "type": "label",
                    "id": "choiceHint",
                    "text": "Checkboxes show both dot and check indicators. Radios include the default dot and explicit check styles.",
                    "multiline": true,
                    "wordWrap": true,
                    "style": {
                      "align": "start",
                      "fg": "#64748b"
                    }
                  },
                  {
                    "type": "checkbox",
                    "id": "dotStyleBox",
                    "text": "Dot-style checkbox",
                    "checked": true,
                    "style": {
                      "indicatorStyle": "dot"
                    }
                  },
                  {
                    "type": "checkbox",
                    "id": "checkStyleBox",
                    "text": "Check-style checkbox",
                    "checked": true,
                    "style": {
                      "indicatorStyle": "check"
                    }
                  },
                  {
                    "type": "checkbox",
                    "id": "disabledRule",
                    "text": "Disabled selected rule",
                    "checked": true,
                    "enabled": false,
                    "style": {
                      "indicatorStyle": "check"
                    }
                  },
                  {
                    "type": "radio",
                    "id": "radioDotA",
                    "group": "notify-mode",
                    "text": "Notify immediately",
                    "checked": true
                  },
                  {
                    "type": "radio",
                    "id": "radioDotB",
                    "group": "notify-mode",
                    "text": "Notify later"
                  },
                  {
                    "type": "radio",
                    "id": "radioCheckA",
                    "group": "approve-mode",
                    "text": "Approve with check style",
                    "checked": true,
                    "style": {
                      "indicatorStyle": "check"
                    }
                  },
                  {
                    "type": "radio",
                    "id": "radioCheckB",
                    "group": "approve-mode",
                    "text": "Escalate with check style",
                    "style": {
                      "indicatorStyle": "check"
                    }
                  }
                ]
              },
              {
                "type": "panel",
                "id": "dataCard",
                "layout": {
                  "type": "col",
                  "gap": 12,
                  "pad": [18, 18, 18, 18]
