                    "items": [
                      {
                        "value": "bj",
                        "text": "Beijing"
                      },
                      {
                        "value": "sh",
                        "text": "Shanghai",
                        "selected": true
                      },
                      {
                        "value": "hz",
                        "text": "Hangzhou"
                      },
                      {
                        "value": "cd",
                        "text": "Chengdu"
                      }
                    ]
                  },
                  {
                    "type": "listbox",
                    "id": "cityList",
                    "items": [
                      {
                        "value": "alpha",
                        "text": "Alpha rollout"
                      },
                      {
                        "value": "beta",
                        "text": "Beta rollout",
                        "selected": true
                      },
                      {
                        "value": "release",
                        "text": "Release rollout"
                      },
                      {
                        "value": "hold",
                        "text": "Hold rollout",
                        "disabled": true
                      }
                    ]
                  }
                ]
              },              {
                "type": "panel",
                "id": "fileCard",
