                "style": {
                  "bg": "#ffffff",
                  "border": "#d6deea",
                  "borderW": 1,
                  "radius": 16
                },
                "children": [
                  {
                    "type": "label",
                    "id": "introTitle",
                    "text": "Coverage",
                    "style": {
                      "size": 18,
                      "weight": "bold",
                      "align": "start",
                      "fg": "#0f172a"
                    }
                  },
                  {
                    "type": "label",
                    "id": "introBody",
                    "text": "This page covers Panel, Modal, Label, Button, EditBox, ProgressBar, CheckBox, RadioButton, ComboBox, ListBox, FilePicker, Image, AnimatedImage, and ScrollView.",
