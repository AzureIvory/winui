                      "weight": "bold",
                      "align": "start"
                    }
                  },
                  {
                    "type": "label",
                    "id": "fileHint",
                    "text": "Open, save, folder, and multi-select file pickers are all present in one section.",
                    "multiline": true,
                    "wordWrap": true,
                    "style": {
                      "align": "start",
                      "fg": "#64748b"
                    }
                  },
                  {
                    "type": "file",
                    "id": "openFile",
                    "value": "README.md",
                    "buttonText": "Open file",
                    "dialogTitle": "Select a source file",
                    "accept": ["*.md", "*.txt", "*.go"]
                  },
                  {
                    "type": "file",
                    "id": "saveFile",
                    "dialog": "save",
                    "buttonText": "Save report",
                    "dialogTitle": "Export the API report",
                    "defaultExt": "txt",
                    "filters": [
                      {
                        "name": "Text Files",
                        "pattern": "*.txt"
                      },
                      {
                        "name": "Markdown",
                        "pattern": "*.md"
                      },
                      {
                        "name": "All Files",
                        "pattern": "*.*"
                      }
                    ],
                    "placeholder": "Choose an output path"
                  },
                  {
                    "type": "file",
                    "id": "folderPick",
                    "dialog": "folder",
                    "buttonText": "Pick folder",
                    "dialogTitle": "Select a workspace folder",
                    "placeholder": "No folder selected"
                  },
                  {
                    "type": "file",
                    "id": "multiFiles",
                    "multiple": true,
                    "buttonText": "Pick files",
                    "dialogTitle": "Select multiple project files",
                    "accept": ["*.go", "*.json", "*.md"],
                    "valueSep": " | ",
                    "placeholder": "No files selected"
                  }
                ]
