{
  "components": {
    "cardSectionHeader": "components/card_section_header.json",
    "standardCard": "components/standard_card.json",
    "headerCard": "components/header_card.json",
    "showcaseScroll": "components/showcase_scroll.json",
    "resultCard": "components/result_card.json",
    "helpModal": "components/help_modal.json",
    "auxRoot": "components/aux_root.json"
  },
  "wins": [
    {
      "id": "main",
      "title": {
        "bind": "demo.windowTitle",
        "default": "WinUI JSON Full Demo"
      },
      "image": "assets/app.png",
      "imageSizeDP": 32,
      "w": 1380,
      "h": 940,
      "minW": 1280,
      "minH": 860,
      "bg": "#f4f7fb",
      "root": {
        "type": "panel",
        "id": "pageRoot",
        "layout": "abs",
        "style": {
          "bg": "#f4f7fb"
        },
        "children": [
          {
            "component": "headerCard"
          },
          {
            "component": "showcaseScroll"
          },
          {
            "component": "resultCard"
          },
          {
            "component": "helpModal"
          }
        ]
      }
    },
    {
      "id": "aux",
      "title": "WinUI JSON Aux",
      "w": 480,
      "h": 320,
      "root": {
        "component": "auxRoot"
      }
    }
  ]
}
